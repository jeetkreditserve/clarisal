# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend,edge-proxy,.clarisal.com,www.clarisal.com
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,https://www.clarisal.com
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,https://www.clarisal.com,https://*.clarisal.com
SESSION_COOKIE_DOMAIN=.clarisal.com
CSRF_COOKIE_DOMAIN=.clarisal.com
# Required when DEBUG=false. Use a real secret, not this placeholder value.
FIELD_ENCRYPTION_KEY=replace-with-a-real-field-encryption-secret
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30

# Database
POSTGRES_DB=clarisal
POSTGRES_USER=clarisal
POSTGRES_PASSWORD=clarisal_dev_password
DATABASE_URL=postgresql://clarisal:clarisal_dev_password@db:5432/clarisal

# Redis
REDIS_URL=redis://redis:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=clarisal-documents
AWS_S3_REGION_NAME=ap-south-1

# Email
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@clarisal.com
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
ZEPTOMAIL_API_KEY=replace-with-zeptomail-api-key
ZEPTOMAIL_FROM_EMAIL=noreply@clarisal.com
ZEPTOMAIL_FROM_NAME=Clarisal

# Frontend
EDGE_PROXY_PORT=8080
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:8000

# App
FRONTEND_URL=https://dev.clarisal.com
DEFAULT_LICENCE_PRICE_PER_MONTH=0.00
CONTROL_TOWER_EMAIL=admin@clarisal.com
CONTROL_TOWER_PASSWORD=replace-with-control-tower-password
SEED_ORGANISATION_NAME=Acme Workforce Pvt Ltd
SEED_ORGANISATION_LICENCE_COUNT=10
SEED_ORGANISATION_EMAIL=hello@acmeworkforce.com
SEED_ORGANISATION_PHONE=+91 9876543210
SEED_ORG_ADMIN_PHONE=+91 9876543210
SEED_ORGANISATION_ADDRESS=42 Residency Road, Bengaluru, Karnataka 560025
SEED_ORGANISATION_COUNTRY_CODE=IN
SEED_ORGANISATION_CURRENCY=INR
SEED_ORG_ADMIN_EMAIL=admin@acmeworkforce.com
SEED_ORG_ADMIN_PASSWORD=replace-with-org-admin-password
SEED_ORG_ADMIN_FIRST_NAME=Aditi
SEED_ORG_ADMIN_LAST_NAME=Rao
SEED_EMPLOYEE_PASSWORD=replace-with-employee-password

# Production notes
# ALLOWED_HOSTS uses Django's leading-dot wildcard support, so `.clarisal.com`
# allows `www.clarisal.com` and other subdomains.
# CSRF_TRUSTED_ORIGINS must include full origins, and wildcard subdomains use
# the `https://*.clarisal.com` form.
